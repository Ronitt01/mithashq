generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  OWNER
  MANAGER
  ACCOUNTANT
  STAFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  accounts      Account[]
  sessions      Session[]
  aiChats       AIChat[]
  notifications Notification[]

  @@index([tenantId])
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plan        Plan     @default(FREE)
  maxShops    Int      @default(1)
  maxUsers    Int      @default(2)
  maxProducts Int      @default(100)
  isDemo      Boolean  @default(false)

  users        User[]
  shops        Shop[]
  categories   Category[]
  products     Product[]
  inventory    Inventory[]
  stockLogs    StockLog[]
  productionBatches ProductionBatch[]
  customers    Customer[]
  deliveries   Delivery[]
  payments     Payment[]
  festivals    Festival[]
  forecasts    Forecast[]
  aiChats      AIChat[]
  notifications Notification[]
}

enum Plan {
  FREE
  GROWTH
  ENTERPRISE
}

model Shop {
  id       String  @id @default(cuid())
  name     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  products          Product[]
  inventory         Inventory[]
  stockLogs         StockLog[]
  productionBatches ProductionBatch[]
  deliveries        Delivery[]
  payments          Payment[]
  forecasts         Forecast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Category {
  id   String @id @default(cuid())
  name String

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

enum Unit {
  KG
  LITRE
  PIECE
  GRAM
  ML
  UNIT
  BOX
  PACKET
}

model Product {
  id            String  @id @default(cuid())
  name          String
  sku           String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  costPrice     Decimal  @db.Decimal(10, 2)
  sellingPrice  Decimal  @db.Decimal(10, 2)
  shelfLifeDays Int?
  unit          Unit     @default(KG)
  isActive      Boolean  @default(true)
  reorderLevel  Decimal? @db.Decimal(10, 2)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId   String?
  shop     Shop?   @relation(fields: [shopId], references: [id])

  inventory     Inventory[]
  stockLogs     StockLog[]
  batchItems    ProductionBatchItem[]
  deliveryItems DeliveryItem[]
  forecastItems ForecastItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([shopId])
  @@index([categoryId])
}

model Inventory {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal @db.Decimal(10, 3)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId   String
  shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  stockLogs StockLog[]

  updatedAt DateTime @updatedAt

  @@unique([productId, shopId])
  @@index([tenantId])
  @@index([shopId])
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  EXPIRED
  DAMAGED
}

model StockLog {
  id       String @id @default(cuid())
  type     StockMovementType
  quantity Decimal @db.Decimal(10, 3)
  reason   String?
  unitCost Decimal? @db.Decimal(10, 2)
  date     DateTime @default(now())

  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId   String
  shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  batchId String?
  batch   ProductionBatch? @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([shopId])
  @@index([productId])
  @@index([date])
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionBatch {
  id          String @id @default(cuid())
  name        String
  plannedDate DateTime
  actualDate  DateTime?
  plannedCost Decimal? @db.Decimal(10, 2)
  actualCost  Decimal? @db.Decimal(10, 2)
  status      ProductionStatus @default(PLANNED)
  notes       String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId   String
  shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items     ProductionBatchItem[]
  stockLogs StockLog[]
  outputs   ProductionOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([shopId])
  @@index([plannedDate])
}

model ProductionBatchItem {
  id         String @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  plannedQty Decimal @db.Decimal(10, 3)
  actualQty  Decimal? @db.Decimal(10, 3)
  unitCost   Decimal? @db.Decimal(10, 2)

  batchId String
  batch   ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productId])
}

model ProductionOutput {
  id       String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal @db.Decimal(10, 3)
  unitCost  Decimal? @db.Decimal(10, 2)
  date      DateTime @default(now())

  batchId String
  batch   ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([productId])
}

enum CustomerType {
  RESTAURANT
  HOTEL
  CAFE
  CATERER
  RETAIL
  OTHER
}

model Customer {
  id          String @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  type        CustomerType @default(RESTAURANT)
  creditLimit Decimal? @db.Decimal(10, 2)
  isActive    Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  deliveries Delivery[]
  payments   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([phone])
}

model Delivery {
  id          String @id @default(cuid())
  date        DateTime @default(now())
  totalAmount Decimal @db.Decimal(10, 2)
  status      DeliveryStatus @default(DELIVERED)
  notes       String?

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  items    DeliveryItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([date])
}

model DeliveryItem {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([productId])
}

enum DeliveryStatus {
  DELIVERED
  PENDING
  CANCELLED
  PARTIAL
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  CREDIT
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  OVERDUE
}

model Payment {
  id        String @id @default(cuid())
  amount    Decimal @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  date      DateTime @default(now())
  reference String?
  notes     String?

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryId String?
  delivery   Delivery? @relation(fields: [deliveryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([deliveryId])
  @@index([date])
}

model Festival {
  id     String @id @default(cuid())
  name   String
  date   DateTime
  impact String?
  region String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  forecasts Forecast[]

  @@index([tenantId])
  @@index([date])
}

model Forecast {
  id         String @id @default(cuid())
  date       DateTime
  confidence Decimal? @db.Decimal(3, 2)
  notes      String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shopId   String
  shop     Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  festivalId String?
  festival   Festival? @relation(fields: [festivalId], references: [id])

  items ForecastItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([shopId])
  @@index([date])
}

model ForecastItem {
  id           String @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  predictedQty Decimal @db.Decimal(10, 3)
  actualQty    Decimal? @db.Decimal(10, 3)
  accuracy     Decimal? @db.Decimal(3, 2)

  forecastId String
  forecast   Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)

  @@index([forecastId])
  @@index([productId])
}

model AIChat {
  id      String @id @default(cuid())
  role    String
  content String @db.Text
  context String? @db.Text

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id       String @id @default(cuid())
  title    String
  message  String
  type     NotificationType
  isRead   Boolean @default(false)
  link     String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  LOW_STOCK
  EXPIRY_ALERT
  OVERDUE_PAYMENT
  PRODUCTION_REMINDER
  SYSTEM
}
